{
    "name": "app_client_ai",
    "version": "1.0.0",
    "description": "AI client application for communicating with a model hosted on a server.",
    "author": "cimo",
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/cimo/App_client_ai.git"
    },
    "type": "module",
    "scripts": {
        "preinstall": "npx -y npm-force-resolutions",
        "delete_dist": "node -e \"const fs = require('fs'); try{ fs.rmdirSync('./dist/', { recursive: true }) } catch{}; process.exit(0);\"",
        "delete_public_js": "node -e \"const fs = require('fs'); try{ fs.rmdirSync('./public/asset/js/', { recursive: true }) } catch{}; process.exit(0);\"",
        "delete_public_style": "node -e \"const fs = require('fs'); try{ fs.rmdirSync('./public/asset/style/', { recursive: true }) } catch{}; process.exit(0);\"",
        "check": "eslint --no-cache --config eslint.config.js",
        "sass": "sass ./src/style/main.scss ./public/asset/style/main.css",
        "build_tsc": "npm run delete_dist && tsc --build tsconfig.tsc.json",
        "build_app": "npm run delete_public_js && npm run delete_public_style && npm run sass && tsc --noEmit --project tsconfig.json && webpack --config webpack.build.js",
        "build": "npm run build_tsc && npm run check && npm run build_app",
        "execute": "nodemon --config nodemon.json",
        "tauri_dev": "tauri dev",
        "tauri_build_linux_x86_64": "tauri build --target x86_64-unknown-linux-gnu",
        "tauri_build_windows_x86_64": "tauri build --runner cargo-xwin --target x86_64-pc-windows-msvc"
    },
    "dependencies": {
        "@cimo/jsmvcfw": "1.5.39",
        "@tauri-apps/api": "2.10.1",
        "@tauri-apps/plugin-log": "2.8.0",
        "@tauri-apps/plugin-dialog": "2.6.0",
        "@tauri-apps/plugin-fs": "2.4.5",
        "@tauri-apps/plugin-http": "2.5.7",
        "@tauri-apps/plugin-opener": "2.5.3"
    },
    "devDependencies": {
        "@types/node": "25.3.0",
        "@types/express": "5.0.0",
        "@types/cookie-parser": "1.4.8",
        "@types/cors": "2.8.17",
        "@typescript-eslint/parser": "8.24.1",
        "@typescript-eslint/eslint-plugin": "8.24.1",
        "typescript": "5.7.2",
        "nodemon": "3.1.9",
        "prettier": "3.4.2",
        "eslint": "9.31.0",
        "eslint-plugin-prettier": "5.2.1",
        "sass": "1.83.0",
        "webpack": "5.105.0",
        "webpack-cli": "6.0.1",
        "webpack-dev-server": "5.2.3",
        "terser-webpack-plugin": "5.4.0",
        "html-webpack-plugin": "5.6.6",
        "compression-webpack-plugin": "12.0.0",
        "esbuild-loader": "4.3.0",
        "@tauri-apps/cli": "2.9.5"
    },
    "resolutions": {}
}
